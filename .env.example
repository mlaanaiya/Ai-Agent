# ==============================================================================
# AI Agent — configuration example (free stack: Gemini + Google Drive)
# Copy to .env and fill in the values.
# ==============================================================================

# --- LLM backend selection ---------------------------------------------------
# "gemini" = Google Gemini free tier (recommended, much more powerful)
# "ollama" = local inference via Ollama (no data leaves the host)
# "openai" = any OpenAI-compatible chat/completions API (OpenAI, proxy, gateway)
LLM_BACKEND=gemini

# --- Gemini (free tier — default) --------------------------------------------
# Get a free API key at https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1M tokens/day, 1500 req/day
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=120

# --- Ollama (local fallback) -------------------------------------------------
# Only used when LLM_BACKEND=ollama
# Install Ollama: https://ollama.com — then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=180

# --- OpenAI-compatible APIs --------------------------------------------------
# Only used when LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=120

# --- MCP Drive server --------------------------------------------------------
# Path to a Google service-account JSON file with Drive scope. The service
# account must be explicitly shared on the target Drive folder.
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/service_account.json
# Root folder ID the agent is allowed to operate on. Required — acts as a
# sandbox. Any request targeting a file outside this subtree is denied.
DRIVE_ROOT_FOLDER_ID=
# Comma-separated list of allowed MIME types for reads (empty = all).
DRIVE_ALLOWED_MIME_TYPES=application/pdf,application/vnd.google-apps.document,application/vnd.google-apps.spreadsheet,text/plain,text/markdown,text/csv
# Max bytes returned by a single read_document call.
DRIVE_MAX_READ_BYTES=2000000
# Audit log destination (JSONL).
MCP_AUDIT_LOG=./audit/mcp-drive.jsonl

# --- MCP client -> server transport -------------------------------------------
# "stdio" launches the MCP server as a child process (recommended for local /
# single-host deployments). "http" connects to a remote MCP server over
# streamable HTTP (e.g. the Gandi-hosted production instance).
MCP_TRANSPORT=stdio
# Only used when MCP_TRANSPORT=http.
MCP_SERVER_URL=https://mcp.example.gandi.net/mcp
MCP_SERVER_TOKEN=
# Optional: JSON config file describing one or more MCP servers for the local
# fallback orchestrator. See config/mcp_servers.example.json.
MCP_SERVERS_CONFIG_FILE=

# --- Enterprise MCP server ---------------------------------------------------
# Approved policy/runbook directory exposed read-only through enterprise tools.
ENTERPRISE_POLICIES_DIR=./config/enterprise_policies
# Outbox where structured enterprise requests are queued as JSON files.
ENTERPRISE_REQUEST_OUTBOX=./var/enterprise_requests
# Audit log for enterprise MCP calls.
ENTERPRISE_AUDIT_LOG=./audit/mcp-enterprise.jsonl
# Hard byte cap for a single policy read.
ENTERPRISE_MAX_POLICY_BYTES=250000
# Allowed request categories for enterprise_create_request.
ENTERPRISE_ALLOWED_REQUEST_TYPES=access,incident,change

# --- Telegram bot channel ----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated whitelist. Leave empty only in local dev if the route is not exposed.
TELEGRAM_ALLOWED_USER_IDS=
# Optional extra restriction on allowed chat ids.
TELEGRAM_ALLOWED_CHAT_IDS=
# Recommended for confidentiality.
TELEGRAM_REQUIRE_PRIVATE_CHAT=true

# --- Orchestrator --------------------------------------------------------------
AGENT_SYSTEM_PROMPT_FILE=./src/orchestrator/prompts/system.md
AGENT_MAX_STEPS=8
AGENT_LOG_LEVEL=INFO

# --- Automation / scheduler -----------------------------------------------------
# Path to a JSON file defining scheduled prompts (see config/jobs.example.json).
AUTOMATION_JOBS_FILE=./config/jobs.json
